# ═══════════════════════════════════════════════════════════
# College Counselor Backend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the guided setup, which generates ENCRYPTION_KEY + JWT_SECRET and
# prompts for the College Scorecard (IPEDS) data API key — and safely KEEPS an
# existing ENCRYPTION_KEY (rotating it would orphan all stored PII):
#   npm run setup            # interactive
#   npm run setup -- --scorecard=YOUR_KEY --yes   # non-interactive

# ─── REQUIRED ───────────────────────────────────────────────

# LLM API key — the server accepts Anthropic, OpenAI, Google, or any
# OpenAI-compatible endpoint (OpenRouter, DeepSeek, Together, Zhipu/GLM,
# Ollama, LM Studio). Set ONE of the keys below. The backend auto-detects
# the provider from the key prefix; per-student BYOK keys take precedence
# when present. See DEPLOY.md → "LLM Providers" for the full matrix.

# Anthropic Claude (server-side only — never sent to browser)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# OpenAI or OpenAI-compatible (OpenRouter / DeepSeek / Together / Zhipu /
# Ollama / LM Studio). Set OPENAI_BASE_URL to point at a compat host.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Google Gemini
GOOGLE_API_KEY=

# Per-tier model overrides (optional — each provider has defaults in
# llm-adapters/tier-defaults.js). Use these when you want, e.g., to pin
# a specific gpt-4o snapshot or a local Ollama model.
LLM_SMALL_MODEL=
LLM_MEDIUM_MODEL=
LLM_LARGE_MODEL=

# Encryption key for parental email storage (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_node_-e_crypto.randomBytes(32).toString(hex)

# Counselor dashboard password (for /api/audit/dashboard)
COUNSELOR_USER=counselor
COUNSELOR_PASS=REPLACE_WITH_A_STRONG_PASSWORD

# ─── OPTIONAL ───────────────────────────────────────────────

# Server port (default: 3001)
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database path (default: ./data/counselor.db)
# DB_PATH=./data/counselor.db

# ─── SMTP (for parental crisis notifications) ──────────────
# Leave blank to queue notifications without sending.
# Supports any SMTP provider: Gmail, SendGrid, Mailgun, SES, etc.

# Orchestration and privacy controls
ENABLE_PII_MASKING=true
DATA_RESIDENCY_REGION=ap-northeast-2

# Multi-agent model roles (provider/model labels only)
ROUTER_PROVIDER=anthropic
ROUTER_MODEL=claude-haiku-4-20250414
COMPLIANCE_PROVIDER=anthropic
COMPLIANCE_MODEL=claude-haiku-4-20250414
STRATEGIST_PROVIDER=anthropic
STRATEGIST_MODEL=claude-opus-4-7

# Optional grounding corpora
# Point FAFSA_GUIDANCE_PATH to extracted text from the current FAFSA PDF.
# Point ADMISSIONS_DEADLINES_PATH to a JSON array of deadline records.
FAFSA_GUIDANCE_PATH=
ADMISSIONS_DEADLINES_PATH=

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-app@gmail.com
# SMTP_PASS=your-app-password    (use App Password, not account password)

# SendGrid example:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key

# Generic SMTP:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=College Counselor Safety <safety@yourcounselorapp.com>

# ─── JWT SESSION TOKENS ─────────────────────────────────
# Secret for signing JWT session tokens (min 32 chars, required in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS_node_-e_crypto.randomBytes(32).toString(hex)
JWT_EXPIRY=1h

# ─── COLLEGE SCORECARD API (for live college data) ──────
# Free API key from https://api.data.gov/signup/
# Enables: 4,000+ institution search, live admission stats,
#           financial aid data, college comparison matrices
SCORECARD_API_KEY=REPLACE_WITH_KEY_FROM_api.data.gov
